<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Welcome Text -->
    <TextView
        android:id="@+id/welcomeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:text="Welcome"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:fontFamily="monospace" />

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/welcomeText"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_active" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace"
            android:text="INITIALIZING..."
            android:textColor="#00E5FF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Hologram View -->
    <com.mrrvk.assistant.ui.HologramView
        android:id="@+id/hologramView"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_below="@id/statusBar"
        android:layout_centerHorizontal="true" />

    <!-- Response Text -->
    <TextView
        android:id="@+id/responseText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/hologramView"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:fontFamily="monospace"
        android:textColor="#B0FFFFFF"
        android:textSize="13sp"
        android:maxLines="3"
        android:ellipsize="end" />

    <!-- Partial Result Text -->
    <TextView
        android:id="@+id/partialText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/responseText"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:fontFamily="monospace"
        android:textColor="#5000E5FF"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Conversation Area -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/partialText"
        android:layout_above="@id/inputBar"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/conversationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp" />
    </ScrollView>

    <!-- Input Bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#15FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/btn_circle"
            android:contentDescription="Microphone"
            android:src="@drawable/ic_mic"
            android:padding="12dp"
            android:scaleType="centerInside" />

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/input_bg"
            android:hint="Type a command..."
            android:textColorHint="#50FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:fontFamily="monospace"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/btn_circle_accent"
            android:contentDescription="Send"
            android:src="@drawable/ic_send"
            android:padding="12dp"
            android:scaleType="centerInside" />
    </LinearLayout>
</RelativeLayout>
